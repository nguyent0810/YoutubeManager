# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Type: Web application
# Authorized redirect: http://localhost:3000/api/auth/callback/google (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js — generate secret: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
# Public URL of the app (no trailing slash). Required on Vercel for OAuth + session.
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (or your custom domain)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Optional: server-side quota (OAuth is primary for user data)
YOUTUBE_API_KEY=
