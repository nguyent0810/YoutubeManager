# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Type: Web application
# Authorized redirect: http://localhost:3000/api/auth/callback/google (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js — generate secret: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_SECRET=
# Public URL of the app (no trailing slash). Required on Vercel for OAuth + session.
# Local: http://localhost:3000
# Vercel: https://your-project.vercel.app (or your custom domain)
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Optional: server-side quota (OAuth is primary for user data)
YOUTUBE_API_KEY=

# Postgres (Neon, Supabase, RDS, …) — required for saved reply templates on /dashboard/comments
# Example: postgresql://user:pass@host.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# Optional feature defaults (Phase G). Per-workspace overrides are stored in Postgres when an owner changes them in Settings.
# When unset, exports and YouTube writes default to enabled.
# FEATURE_EXPORTS_DEFAULT=false
# FEATURE_YOUTUBE_WRITES_DEFAULT=false
# AI-assisted features (Gemini). Default off; owner enables per workspace in Settings.
# FEATURE_AI_DEFAULT=false

# Optional: Google AI Studio API key (server-only). Users can also save a personal key in Settings.
# GEMINI_API_KEY=
# Optional model id (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash
# Optional: separate secret for encrypting personal Gemini keys at rest (defaults to AUTH_SECRET)
# GEMINI_KEY_ENCRYPTION_SECRET=
