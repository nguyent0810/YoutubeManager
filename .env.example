# Google OAuth (Google Cloud Console → APIs & Services → Credentials)
# Type: Web application
# Authorized redirect: http://localhost:3000/api/auth/callback/google (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js — generate: openssl rand -base64 32 (set one or both)
AUTH_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optional: server-side quota (OAuth is primary for user data)
YOUTUBE_API_KEY=
