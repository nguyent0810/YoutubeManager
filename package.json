{
  "name": "youtube-channel-manager",
  "version": "1.0.0",
  "description": "Desktop YouTube Channel Manager for Windows",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "dev": "npm run build && electron .",
    "dev:web": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "electron": "electron .",
    "start": "npm run build && electron .",
    "start:web": "vite",
    "package": "npm run build && npx electron-packager . youtube-manager --platform=win32 --arch=x64 --out=dist-packager --overwrite",
    "build:electron": "npm run build && electron-builder",
    "build:win": "npm run build && electron-builder --win",
    "dist": "npm run build && electron-builder --win --publish=never",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": [
    "youtube",
    "channel-manager",
    "desktop",
    "electron",
    "windows"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "vite": "^5.0.8",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@types/react-big-calendar": "^1.16.2",
    "autoprefixer": "^10.4.16",
    "axios": "^1.6.2",
    "clsx": "^2.0.0",
    "date-fns": "^3.6.0",
    "electron-store": "^8.1.0",
    "googleapis": "^129.0.0",
    "keytar": "^7.9.0",
    "lucide-react": "^0.303.0",
    "moment": "^2.30.1",
    "node-fetch": "^2.7.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-beautiful-dnd": "^13.1.1",
    "react-big-calendar": "^1.19.4",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^18.2.0",
    "react-dropzone": "^14.2.3",
    "react-hot-toast": "^2.4.1",
    "react-router-dom": "^6.20.1",
    "react-window": "^1.8.11",
    "recharts": "^2.8.0",
    "tailwindcss": "^3.3.6"
  },
  "build": {
    "appId": "com.yourcompany.youtube-channel-manager",
    "productName": "YouTube Channel Manager",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "sign": false,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "YouTube-Manager-Portable.exe"
    }
  }
}
