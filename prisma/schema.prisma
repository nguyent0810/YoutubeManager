generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members             OrganizationMember[]
  invites             OrganizationInvite[]
  savedReplies        SavedReply[]
  pipelineItems       PipelineItem[]
  featureFlags        OrgFeatureFlag[]
  metadataTemplates   MetadataTemplate[]
  commentAssignments  CommentThreadAssignment[]
  auditLogs           AuditLog[]
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           OrgRole      @default(VIEWER)
  /** Per-user opt-in for AI-assisted features (bulk metadata, reply polish). */
  aiOptIn        Boolean      @default(false)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model OrganizationInvite {
  id             String       @id @default(cuid())
  organizationId String
  email          String
  role           OrgRole      @default(VIEWER)
  token          String       @unique
  expiresAt      DateTime
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// Per-org feature overrides (Phase G). If no row, env defaults apply.
model OrgFeatureFlag {
  organizationId String
  key            String
  enabled        Boolean      @default(false)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, key])
}

/// Saved metadata presets for bulk/single upload (per workspace).
model MetadataTemplate {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  title          String?      @db.Text
  description    String?      @db.Text
  tags           String?      @db.Text
  categoryId     String?
  visibility     String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

/// Optional assignee for a comment thread (moderation).
model CommentThreadAssignment {
  id             String       @id @default(cuid())
  organizationId String
  videoId        String
  threadId       String
  assigneeUserId String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, threadId])
  @@index([organizationId])
  @@index([assigneeUserId])
}

model AuditLog {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  action         String
  entity         String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, createdAt])
}

/// Canned replies for the comments UI (scoped to organization).
model SavedReply {
  id             String        @id @default(cuid())
  userId         String
  organizationId String?
  title          String
  body           String        @db.Text
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([organizationId])
}

enum PipelineStatus {
  BACKLOG
  PLANNED
  IN_PROGRESS
  REVIEW
  SCHEDULED
  PUBLISHED
}

/// Content pipeline cards (scoped to organization).
model PipelineItem {
  id             String          @id @default(cuid())
  userId         String
  organizationId String?
  title          String
  notes          String          @db.Text
  status         PipelineStatus  @default(BACKLOG)
  dueDate        DateTime?
  youtubeVideoId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  organization   Organization?   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([organizationId])
}
